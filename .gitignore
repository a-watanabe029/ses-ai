secrets/
credentials.json
token.json
*.token.json
# .env … 設定値・素の鍵（SHEET_ID・ANTHROPIC_API_KEY 等）
.env
.env.*
# テンプレはコミットする
!.env.example

# 中間データ（メール本文・生データ）
data/

# Python
.venv/
__pycache__/
*.pyc

# macOS
.DS_Store

